{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "lint",
      "inherits": "debug",
      "displayName": "clang-tidy",
      "binaryDir": "${sourceDir}/build/lint",
      "cacheVariables": {
        "NEURIPLO_ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "asan",
      "inherits": "debug",
      "displayName": "AddressSanitizer + UBSan",
      "binaryDir": "${sourceDir}/build/asan",
      "cacheVariables": {
        "NEURIPLO_SANITIZER": "address"
      }
    },
    {
      "name": "tsan",
      "inherits": "debug",
      "displayName": "ThreadSanitizer",
      "binaryDir": "${sourceDir}/build/tsan",
      "cacheVariables": {
        "NEURIPLO_SANITIZER": "thread"
      }
    },
    {
      "name": "ubsan",
      "inherits": "debug",
      "displayName": "UndefinedBehaviorSanitizer",
      "binaryDir": "${sourceDir}/build/ubsan",
      "cacheVariables": {
        "NEURIPLO_SANITIZER": "undefined"
      }
    },
    {
      "name": "real-onnx",
      "inherits": "debug",
      "displayName": "Real neuriplo ONNX Runtime",
      "binaryDir": "${sourceDir}/build/real-onnx",
      "cacheVariables": {
        "NEURIPLO_RUNTIME_ENABLE_REAL_NEURIPLO": "ON",
        "NEURIPLO_RUNTIME_NEURIPLO_SOURCE_DIR": "${sourceDir}/../neuriplo",
        "DEFAULT_BACKEND": "ONNX_RUNTIME",
        "BUILD_INFERENCE_ENGINE_TESTS": "OFF"
      }
    },
    {
      "name": "grpc",
      "inherits": "debug",
      "displayName": "gRPC V2 support",
      "binaryDir": "${sourceDir}/build/grpc",
      "cacheVariables": {
        "NEURIPLO_RUNTIME_ENABLE_GRPC": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" },
    { "name": "lint", "configurePreset": "lint" },
    { "name": "asan", "configurePreset": "asan" },
    { "name": "tsan", "configurePreset": "tsan" },
    { "name": "ubsan", "configurePreset": "ubsan" },
    { "name": "real-onnx", "configurePreset": "real-onnx" },
    { "name": "grpc", "configurePreset": "grpc" }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ubsan",
      "configurePreset": "ubsan",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "real-onnx",
      "configurePreset": "real-onnx",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "grpc",
      "configurePreset": "grpc",
      "output": { "outputOnFailure": true }
    }
  ]
}
