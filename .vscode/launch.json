{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug runtime",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/neuriplo-kserve-runtime",
      "args": [
        "--host", "127.0.0.1",
        "--port", "8080",
        "--model-name", "demo",
        "--backend", "stub"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "cmake: build debug"
    },
    {
      "name": "Debug unit tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/neuriplo-kserve-runtime-tests",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "cmake: build debug"
    }
  ]
}
